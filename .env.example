# PowerPost — example environment variables
# Copy this file to .env and fill in real values for the variables you need.
# Anything left blank will fall back to safe demo defaults where possible.

# ---- API ----
PORT=4000
DATABASE_URL=postgres://powerpost:powerpost@localhost:5433/powerpost

# Auth secrets. Replace with high-entropy values in any non-local environment.
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me

# LLM (Anthropic Claude)
# Without a key the API runs in "echo mode" and produces deterministic stub
# drafts so the UI flow is fully exercisable end-to-end.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_GENERATION=claude-sonnet-4-6
ANTHROPIC_MODEL_PREVIEW=claude-haiku-4-5

# Unipile (LinkedIn integration)
# Without these the API runs in demo mode and returns seeded sample posts so
# the rest of the experience can be built and tested.
UNIPILE_API_KEY=
UNIPILE_DSN=
UNIPILE_DEMO_MODE=true
# Public base URL of THIS API so Unipile can reach our webhook.
# For Codespaces this is the forwarded port URL, e.g.
#   https://laughing-spoon-4q77w65j9vvrfjjp5-4000.app.github.dev
# In production this is your public API origin. The webhook path
# (/webhooks/unipile) is appended automatically.
UNIPILE_NOTIFY_URL=

# CORS origin for the web app
WEB_ORIGIN=http://localhost:5173

# ---- Web ----
VITE_API_URL=http://localhost:4000
